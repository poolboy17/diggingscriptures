---
/**
 * ================================================================================
 * RESEARCH PAGE TEMPLATE
 * ================================================================================
 * Purpose: Biblical archaeology blog posts (imported from WordPress)
 * Function: Topical authority / informational SEO arm
 * 
 * MONETIZATION: NEVER — pure informational content
 * ================================================================================
 */

import BaseLayout from './BaseLayout.astro';
import CdnImage from '../components/CdnImage.astro';

interface Props {
    title: string;
    description: string;
    category: string;
    pubDate?: Date;
    image?: string;
    imageAlt?: string;
    imageCredit?: string;
    imageWidth?: number;
    imageHeight?: number;
}

const { title, description, category, pubDate, image, imageAlt, imageCredit, imageWidth, imageHeight } = Astro.props;

const imgW = imageWidth || 1280;
const imgH = imageHeight || 853;

const categoryLabels: Record<string, string> = {
    'biblical-archaeology': 'Biblical Archaeology',
    'scripture': 'Scripture Studies',
    'excavations': 'Excavations & Sites',
    'artifacts': 'Artifacts & Discoveries',
    'faith': 'Faith & Theology',
};
---

<BaseLayout title={title} description={description} breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Research', url: '/research' },
    { name: categoryLabels[category] || category, url: `/research/${category}` },
    { name: title, url: Astro.url.pathname },
]}>
    <article class="section">
        <div class="container">
            <header class="mb-10">
                <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem;">
                    <a href="/research" class="badge" style="text-decoration:none;">Research</a>
                    <a href={`/research/${category}`} class="badge" style="text-decoration:none;">
                        {categoryLabels[category] || category}
                    </a>
                </div>

                {image && (
                    <div class="hero-image mb-8 rounded-xl overflow-hidden">
                        <CdnImage src={image} alt={imageAlt || title} loading="eager" fetchpriority="high" width={imgW} height={imgH} sizes="(max-width: 900px) 100vw, 900px" class="w-full object-cover rounded-xl" style="max-height:420px;aspect-ratio:3/2;" />
                        {imageCredit && <p class="text-xs text-text-light mt-2">{imageCredit}</p>}
                    </div>
                )}

                <h1 class="mb-4">{title}</h1>
                <p class="text-lg text-text-muted leading-relaxed mb-4">{description}</p>
                {pubDate && (
                    <time datetime={pubDate.toISOString()} class="text-sm text-text-light">
                        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                )}
            </header>

            <section class="content">
                <slot />
            </section>
        </div>
    </article>
</BaseLayout>
